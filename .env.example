# Core service settings
GROOVARR_PORT=7077
GROOVARR_DB_PASSWORD=change_me
GROOVARR_DATA_DIR=./groovarr-data
GROOVARR_INTEGRATION_NETWORK=docker_media-network
BEETS_LIBRARY_PATH=/absolute/path/to/media/music-beets/library

# Distribution images
# The default values in docker-compose.yml are placeholders.
# Override these with your published image names when packaging Groovarr.
GROOVARR_APP_IMAGE=ghcr.io/your-org/groovarr:latest
GROOVARR_DB_IMAGE=ghcr.io/your-org/groovarr-db:latest
GROOVARR_DOWNLOADER_IMAGE=ghcr.io/your-org/groovarr-downloader:latest
GROOVARR_IMPORTER_IMAGE=ghcr.io/your-org/groovarr-importer:latest

# Navidrome integration
# Required in V1.
# NAVIDROME_DATA_PATH must point at the Navidrome data directory that contains navidrome.db.
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USERNAME=your_navidrome_username
NAVIDROME_PASSWORD=your_navidrome_password
NAVIDROME_DATA_PATH=/absolute/path/to/navidrome/data

# Lidarr integration
# Required only for Lidarr-backed workflows such as add/search/cleanup actions.
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=your_lidarr_api_key
LIDARR_ROOT_FOLDER_PATH=/music
LIDARR_QUALITY_PROFILE_ID=1
LIDARR_METADATA_PROFILE_ID=1

# Model backend
# At least one provider key should be set.
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
DEFAULT_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile
DISCOVERY_MODEL=
HF_DISCOVERY_MODEL=
GROQ_DISCOVERY_MODEL=
AGENT_PROMPT_LAYOUT=split
AGENT_LOG_MODEL_USAGE=true
GROQ_CHAT_COMPLETIONS_URL=
HUGGINGFACE_CHAT_COMPLETIONS_URL=

# Embeddings
# Optional. Leave blank to run sync without embeddings.
EMBEDDINGS_ENDPOINT=
SIMILARITY_DEFAULT_PROVIDER=hybrid
SIMILARITY_HYBRID_LOCAL_WEIGHT=0.45
SIMILARITY_HYBRID_AUDIOMUSE_WEIGHT=0.55

# AudioMuse integration
# Optional. When configured, Groovarr can use AudioMuse for sonic candidate generation
# and merge those results with local library similarity.
AUDIOMUSE_URL=
AUDIOMUSE_TRACKS_PATH=/api/similar_tracks
AUDIOMUSE_ARTISTS_PATH=/api/similar_artists
AUDIOMUSE_HEALTH_PATH=/
AUDIOMUSE_TIMEOUT_SECONDS=8
AUDIOMUSE_BOOTSTRAP_ENABLED=true
AUDIOMUSE_BOOTSTRAP_RECENT_ALBUMS=0
AUDIOMUSE_BOOTSTRAP_TOP_N_MOODS=5
AUDIOMUSE_PORT=8000
AUDIOMUSE_POSTGRES_USER=audiomuse
AUDIOMUSE_POSTGRES_PASSWORD=audiomusepassword
AUDIOMUSE_POSTGRES_DB=audiomusedb
AUDIOMUSE_AI_MODEL_PROVIDER=NONE
AUDIOMUSE_CLAP_ENABLED=true
AUDIOMUSE_USE_GPU_CLUSTERING=false

# Last.fm album enrichment
# Optional. Used by Groovarr's own album metadata enrichment pass.
SYNC_LASTFM_ENABLED=false
LASTFM_API_KEY=
SYNC_LASTFM_BASE_URL=
SYNC_LASTFM_ALBUMS_PER_SYNC=10

# MusicBrainz album enrichment
# Optional. Used by Groovarr's own album metadata enrichment pass.
SYNC_MUSICBRAINZ_ENABLED=false
SYNC_MUSICBRAINZ_ALBUMS_PER_SYNC=5
SYNC_MUSICBRAINZ_BASE_URL=
SYNC_MUSICBRAINZ_USER_AGENT=
SYNC_MUSICBRAINZ_MIN_GAP_MS=1100

# Soulseek downloader credentials
# Required for the bundled groovarr-downloader service.
SLSK_USERNAME=your_soulseek_username
SLSK_PASSWORD=your_soulseek_password

# Container runtime defaults
TZ=UTC

# Reconcile runs on startup and after queue additions, then keeps checking every
# N minutes until the playlist-reconcile queue is empty.
PLAYLIST_RECONCILE_INTERVAL_MINUTES=3

# Sync tuning
SYNC_INTERVAL_MINUTES=15
SYNC_ARTIST_LIMIT=150
SYNC_ALBUM_LIMIT=300
SYNC_TRACK_LIMIT=1200
SYNC_EMBED_BATCH_SIZE=100
SYNC_EMBED_BATCH_PAUSE_MS=120
SYNC_EMBED_RETRIES=2
SYNC_EMBED_RETRY_BACKOFF_MS=250

# Chat and approval tuning
AGENT_MAX_ITERATIONS=6
AGENT_MAX_COMPLETION_TOKENS=450
AGENT_MAX_TOOL_RESULT_CHARS=2200
MAX_CHAT_BODY_BYTES=32768
CHAT_REQUEST_TIMEOUT_SEC=25
CHAT_MAX_HISTORY_MESSAGES=12
CHAT_MAX_HISTORY_MESSAGE_CHARS=1200
PENDING_ACTION_TTL_MINUTES=30
PENDING_ACTION_TIMEOUT_SEC=90
RECENT_LISTENING_SUMMARY_TTL_SECONDS=45
HTTP_READ_HEADER_TIMEOUT_SEC=5
HTTP_READ_TIMEOUT_SEC=10
HTTP_WRITE_TIMEOUT_SEC=40
HTTP_IDLE_TIMEOUT_SEC=60
